# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=local
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Data directories
# -----------------------------------------------------------------------------
DATA_DIR=/data
RAW_DIR=${DATA_DIR}/raw
MARKDOWN_DIR=${DATA_DIR}/markdown
SAMPLE_OUTPUT_DIR=${DATA_DIR}/sample_output
CRAWL_CHECKPOINT_FILE=${DATA_DIR}/crawl_checkpoint.json
EMBEDDING_CACHE_PATH=${DATA_DIR}/embedding_cache.sqlite3

# -----------------------------------------------------------------------------
# Source websites
# -----------------------------------------------------------------------------
SOURCE_URL=https://lex.uz/
SCRAPE_ENGLISH=true
SCRAPE_UZBEK=true
SCRAPE_RUSSIAN=true

# -----------------------------------------------------------------------------
# Scraper behavior
# -----------------------------------------------------------------------------
USE_PLAYWRIGHT=false
MAX_PAGES=1000
REQUEST_TIMEOUT_SECONDS=30
REQUEST_RETRIES=3
THROTTLE_MIN_SECONDS=1.0
THROTTLE_MAX_SECONDS=3.5

# -----------------------------------------------------------------------------
# Neo4j
# IMPORTANT:
# Change NEO4J_PASSWORD before using this outside local development.
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j-password
NEO4J_DATABASE=neo4j
NEO4J_VEXTOR_DIMENSION=1536

# -----------------------------------------------------------------------------
# Embeddings
# Default provider is local SentenceTransformers.
# Set EMBEDDING_PROVIDER=openai to use OpenAI embeddings.
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=sentence_transformers
SENTENCE_TRANSFORMERS_MODEL=sentence-transformers/all-MiniLM-L6-v2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=your-openai-api-key
OPENAI_EMBEDDING_DIMENSION=1024

# -----------------------------------------------------------------------------
# LLM topic extraction and answer synthesis
# Values:
#   fallback - deterministic offline fallback
#   openai   - OpenAI API
# -----------------------------------------------------------------------------
TOPIC_LLM_PROVIDER=fallback
OPENAI_CHAT_MODEL=gpt-4o-mini
TOPIC_EXTRACTION_MAX_RETRIES=3
SYNTHESIS_PROVIDER=fallback


# -----------------------------------------------------------------------------
# Chunking
# -----------------------------------------------------------------------------
CHUNCK_MIN_TOKENS=500
CHUNCK_MAX_TOKENS=900
CHUNCK_OVERLAP_TOKENS=120

# -----------------------------------------------------------------------------
# Hybrid retrieval
# -----------------------------------------------------------------------------
HYBRID_VECTOR_WEIGHT=0.65
HYBRID_KEYWORD_WEIGHT=0.35
RERANKING_ENABLED=false
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# -----------------------------------------------------------------------------
# Topic merging
# -----------------------------------------------------------------------------
TOPIC_MERGE_SIMILARITY_THRESHOLD=0.88